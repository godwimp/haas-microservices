// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// RBAC Schema
// ============================================

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  first_name String
  last_name  String
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  // Relations
  position_id Int
  position    Position @relation(fields: [position_id], references: [id])

  @@map("users")
}

model Position {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  // Relations
  users               User[]
  position_permissions PositionPermission[]

  @@map("positions")
}

model Permission {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  resource    String // e.g., 'USER', 'TRANSACTION', 'REPORT'
  action      String // e.g., 'VIEW', 'ADD', 'UPDATE', 'DELETE'
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  // Relations
  position_permissions PositionPermission[]

  @@map("permissions")
}

model PositionPermission {
  id            Int      @id @default(autoincrement())
  position_id   Int
  permission_id Int
  created_at    DateTime @default(now())

  // Relations
  position   Position   @relation(fields: [position_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([position_id, permission_id])
  @@map("position_permissions")
}

model Trap {
  id            String     @id @default(uuid())
  path          String     @unique // e.g "/admin/config"
  method        String     @default("*") // GET, POST, PUT, DELETE, * (any)
  severity      String     @default("HIGH") // LOW, MEDIUM, HIGH, CRITICAL
  response_code Int        @default(404) // 200, 404, 500, 403
  response_body Json?
  description   String?    // Fake "admin panel"
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  // Relations
  trap_logs     TrapLog[]

  @@map("traps")
}

model TrapLog {
  id             String     @id @default(uuid())
  trap_id        String
  ip_address     String
  method         String
  user_agent     String?
  headers        Json? // all request headers
  query_params   Json?
  body           Json?
  country_code   String?
  is_vpn         Boolean?
  risk_score     Int?       @default(0)
  created_at     DateTime   @default(now())

  // Relations
  trap           Trap       @relation(fields: [trap_id], references: [id], onDelete: Cascade)

  @@map("trap_logs")
  @@index([trap_id])
  @@index([ip_address])
  @@index([created_at])
  @@index([risk_score])
}
